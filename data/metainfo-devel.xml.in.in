<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID@.Devel</id>
  <icon type="stock">@APP_ID@.Devel</icon>
  <name>Atomic Control Center</name>
  <summary>Control center for ALT Atomic (Devel build)</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <description>
    <p>
      Control center for ALT Atomic
    </p>
  </description>
  <translation type="gettext">atomic-control-center</translation>
  <custom>
    <value key="Purism::form_factor">mobile</value>
  </custom>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>
  <branding>
    <color type="primary" scheme_preference="light">#ffffff</color>
    <color type="primary" scheme_preference="dark">#000000</color>
  </branding>
  <content_rating type="oars-1.1"></content_rating>
  <screenshots>
    <screenshot type="default">
      <image>https://altlinux.space/alt-gnome/Foldy/raw/tag/v4.1/app/data/images/1-start-page.png</image>
      <caption>Start page</caption>
    </screenshot>
  </screenshots>
  <launchable type="desktop-id">@APP_ID@.Devel.desktop</launchable>
  <releases>
    <!-- Need for about in devel version -->
    <release version="@VERSION@" date="@DATE@" type="development">
      <description>
        <p>Sorry @USER@! But my release note is in another metainfo</p>
      </description>
    </release>
  </releases>
  <url type="homepage">@HOMEPAGE@</url>
  <url type="bugtracker">@BUGTRACKER@</url>
  <url type="help">@HELP@</url>
  <developer id="org.altlinux">
    <name>ALT Linux Team</name>
  </developer>
  <categories>
    <category>Utility</category>
    <category>GNOME</category>
    <category>GTK</category>
  </categories>
  <provides>
    <binary>atomic-control-center</binary>
  </provides>
</component>
